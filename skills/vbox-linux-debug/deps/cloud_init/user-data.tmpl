#cloud-config
hostname: ${HOSTNAME}
ssh_pwauth: false

users:
  - default
  - name: ${SSH_USER}
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    groups: [plugdev, sudo, dialout]
    ssh_authorized_keys:
      - ${SSH_PUBKEY}

package_update: true
package_upgrade: false
packages:
  - libusb-1.0-0
  - usbutils
  - rsync
  - python3
  - openssh-server
  - unzip
  - curl

runcmd:
  - systemctl enable --now ssh
  - mkdir -p /etc/udev/rules.d
  - bash -c 'echo "SUBSYSTEM==\"usb\", MODE=\"0666\", GROUP=\"plugdev\"" > /etc/udev/rules.d/99-vbld-usb.rules'
  - udevadm control --reload-rules
  - udevadm trigger
  - usermod -aG plugdev ${SSH_USER}

growpart:
  mode: auto
  devices: ['/']
  ignore_growroot_disabled: false
resize_rootfs: true
